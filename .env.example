# Copy to .env and fill in your values.

# --- LLM (pick one) ---

# OpenAI
OPENAI_API_KEY=your_openai_key_here
LLM_MODEL=gpt-4o-mini

# OR: Ollama (fully offline, no key needed)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# LLM_MODEL=llama3

# --- Images (pick one, both free) ---
# Pexels (recommended): pexels.com/api — free, topic-relevant images
PEXELS_API_KEY=your_pexels_key_here

# OR Unsplash: unsplash.com/developers — free, topic-relevant images
# UNSPLASH_ACCESS_KEY=your_unsplash_access_key_here

# Without either key: picsum.photos is used (random images, not topic-relevant)
